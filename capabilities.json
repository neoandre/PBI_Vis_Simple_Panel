{
  "privileges": [],
  "dataRoles": [
    {
      "name": "value",
      "displayName": "Wartość",
      "kind": "Measure",
      "requiredTypes": [ { "numeric": true }, { "integer": true } ]
    },
    {
      "name": "goal",
      "displayName": "Cel",
      "kind": "Measure",
      "requiredTypes": [ { "numeric": true }, { "integer": true } ]
    },
    {
      "name": "tooltips",
      "displayName": "Tooltip fields",
      "kind": "GroupingOrMeasure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "value": { "max": 1 }, "goal": { "max": 1 } }
      ],
      "categorical": {
        "values": {
          "select": [
            { "bind": { "to": "value" } },
            { "bind": { "to": "goal" } },
            { "for":  { "in": "tooltips" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "goalLabel": {
      "displayName": "Cel (etykieta)",
      "properties": {
        "fontFamily": { "type": { "formatting": { "fontFamily": true } } },
        "fontSize":   { "type": { "formatting": { "fontSize": true } } },
        "bold":       { "type": { "bool": true } },
        "position": {
          "displayName": "Pozycja względem wartości",
          "type": {
            "enumeration": [
              { "displayName": "Nad",     "value": "above" },
              { "displayName": "Pod",     "value": "below" },
              { "displayName": "Z lewej", "value": "left"  },
              { "displayName": "Z prawej","value": "right" }
            ]
          }
        }
      }
    },
    "tooltip": {
      "displayName": "Tooltip",
      "properties": {
        "enabled":   { "displayName": "Włącz tooltip", "type": { "bool": true } },
        "title":     { "displayName": "Tytuł",         "type": { "text": true } },
        "showValue": { "displayName": "Pokaż wartość", "type": { "bool": true } },
        "showGoal":  { "displayName": "Pokaż cel",     "type": { "bool": true } },
        "showFields":{ "displayName": "Pola dodatkowe (z roli Tooltip fields)", "type": { "bool": true } }
      }
    }
  }
}
